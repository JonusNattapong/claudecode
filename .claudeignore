# .claudeignore
# Files and directories Claude should skip to save tokens and avoid noise.

# Build outputs
dist/
build/
out/
.next/
*.min.js
*.bundle.js

# Dependencies
node_modules/
.pnp.*
.yarn/

# IDE & editor
.vscode/
.idea/
*.swp
*.swo
*~

# OS files
.DS_Store
Thumbs.db
desktop.ini

# Logs & temp
*.log
*.tmp
*.bak
coverage/
.nyc_output/

# Binary & media
*.png
*.jpg
*.jpeg
*.gif
*.ico
*.svg
*.mp4
*.webm
*.woff
*.woff2
*.ttf
*.eot

# Lock files (read-only, too large)
bun.lockb
package-lock.json
yarn.lock
pnpm-lock.yaml

# Test snapshots (large, auto-generated)
__snapshots__/

# Compiled output
*.d.ts
*.js.map
*.d.ts.map
